interface dev.attezt.Agent

type Status (
  ek: string,
  enrolled: bool,
  acmeServer: string,
  attestationServer: string
)

type CertificateChain (
  device: string,
  intermediate: string
) 

method GetStatus() -> (status: Status)
method EnrollDevice() -> ()
method GetCertificate() -> (chain: CertificateChain)
method RenewCertificate() -> ()
